# Frontend
# Netlify can leave this empty to keep using the /api proxy from netlify.toml.
# GitHub Pages should set this to the Render backend URL, including /api.
VITE_API_BASE_URL="https://your-render-service.onrender.com/api"
VITE_BASE_PATH="/"

# Backend
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
PORT=4000
CLIENT_ORIGINS="http://localhost:5173,http://localhost:5174,https://your-netlify-site.netlify.app,https://your-github-username.github.io"
NODE_ENV="development"

# Admin seed account
ADMIN_EMAIL="admin@example.com"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-this-password"

# Local AI agent backend only. Never expose these as VITE_* variables.
ARK_API_KEY="your-ark-api-key"
ARK_MODEL_ID="doubao-seed-2-0-lite-260428"
ARK_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
