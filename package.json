{
  "name": "campus-service-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "server:dev": "node ./node_modules/nodemon/bin/nodemon.js server/src/index.js",
    "server:start": "node server/src/index.js",
    "prisma:migrate": "node ./node_modules/prisma/build/index.js migrate dev --schema server/prisma/schema.prisma",
    "prisma:generate": "node ./node_modules/prisma/build/index.js generate --schema server/prisma/schema.prisma",
    "prisma:deploy": "node ./node_modules/prisma/build/index.js migrate deploy --schema server/prisma/schema.prisma",
    "prisma:studio": "node ./node_modules/prisma/build/index.js studio --schema server/prisma/schema.prisma",
    "prisma:seed": "node server/prisma/seed.js",
    "server:build": "npm run prisma:generate && npm run prisma:deploy",
    "build": "node ./node_modules/typescript/bin/tsc -b && node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview"
  },
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "autoprefixer": "^10.4.20",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "framer-motion": "^12.23.24",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "postcss": "^8.4.49",
    "prisma": "^6.18.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^3.4.17",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.3",
    "vite": "^7.1.0",
    "nodemon": "^3.1.10"
  }
}
